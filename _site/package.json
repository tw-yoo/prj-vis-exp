{
  "name": "prj-vis-exp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:5174": "vite --port 5174",
    "dev:5713": "vite --port 5713",
    "build": "npm run check:draw-support-sync && npm run check:authoring-style && npm run check:ide-hints && npm run check:src-boundary && npm run check:arch-boundary && tsc -b && vite build",
    "lint": "eslint .",
    "check:node": "node scripts/check-node-version.mjs",
    "check:public-modules": "node scripts/check-public-module-links.mjs",
    "check:draw-support-sync": "node scripts/check-draw-support-sync.mjs",
    "check:authoring-style": "node scripts/check-authoring-no-object.mjs",
    "check:ide-hints": "node scripts/check-ide-parameter-hints.mjs",
    "check:src-boundary": "node scripts/check-src-engine-boundary.mjs",
    "check:arch-boundary": "node scripts/check-architecture-boundary.mjs",
    "docs:draw-authoring-typedoc-json": "node scripts/generate-authoring-typedoc-json.mjs",
    "docs:draw-authoring-dsl": "npm run docs:draw-authoring-typedoc-json && node scripts/generate-draw-authoring-dsl-doc.mjs --typedoc-json .cache/typedoc-authoring.json",
    "docs:draw-support-matrix": "node scripts/generate-draw-support-matrix.mjs",
    "docs:draw-test-cases": "node scripts/generate-draw-test-cases.mjs",
    "docs:draw": "npm run docs:draw-authoring-dsl && npm run docs:draw-support-matrix && npm run docs:draw-test-cases",
    "pretest:e2e": "npm run check:node && npm run check:public-modules && npm run check:draw-support-sync && npm run check:authoring-style && npm run check:ide-hints && npm run check:src-boundary && npm run check:arch-boundary",
    "pretest:e2e:headed": "npm run check:node && npm run check:public-modules && npm run check:draw-support-sync && npm run check:authoring-style && npm run check:ide-hints && npm run check:src-boundary && npm run check:arch-boundary",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "preview": "vite preview"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "nodejs-polars": "^0.21.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vega": "^5.30.0",
    "vega-embed": "^6.25.0",
    "vega-lite": "^5.17.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@eslint/js": "^9.39.1",
    "@types/d3": "^7.4.3",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}
