{
  "$schema": "https://vega.github.io/schema/vega-lite/v3.0.0-rc4.json",
  "data": {
    "url": "data/test/data/example_filter.csv"
  },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "month",
      "title": "month",
      "type": "ordinal",
      "timeUnit": "month",
      "sort": null
    },
    "xOffset": {
      "field": "weather",
      "type": "nominal"
    },
    "y": {
      "field": "count",
      "type": "quantitative",
      "axis": { "grid": false }
    },
    "color": {
      "field": "weather",
      "type": "nominal"
    }
  }
}