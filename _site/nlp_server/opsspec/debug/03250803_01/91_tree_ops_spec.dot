digraph OpsSpecTree {
  graph [rankdir=LR, bgcolor="white"];
  node [shape=box, style="rounded,filled", fillcolor="white", fontname="Helvetica"];
  edge [color="#666666"];
  subgraph "cluster_ops" {
    label="ops";
    color="#bbbbbb";
    style="rounded,filled";
    fillcolor="#e8f0fe";
    "n1" [label="n1 sum (ops) field=Revenue_Million_Euros group=Commercial"];
  }
  subgraph "cluster_ops2" {
    label="ops2";
    color="#bbbbbb";
    style="rounded,filled";
    fillcolor="#e8f5e9";
    "n2" [label="n2 scale (ops2)"];
  }
  subgraph "cluster_ops3" {
    label="ops3";
    color="#bbbbbb";
    style="rounded,filled";
    fillcolor="#e8f5e9";
    "n3" [label="n3 sum (ops3) field=Revenue_Million_Euros group=Matchday"];
  }
  subgraph "cluster_ops4" {
    label="ops4";
    color="#bbbbbb";
    style="rounded,filled";
    fillcolor="#e8f5e9";
    "n4" [label="n4 scale (ops4)"];
  }
  subgraph "cluster_ops5" {
    label="ops5";
    color="#bbbbbb";
    style="rounded,filled";
    fillcolor="#e8f5e9";
    "n5" [label="n5 diff (ops5) field=Revenue_Million_Euros"];
  }
  "n1" -> "n2";
  "n3" -> "n4";
  "n2" -> "n5";
  "n4" -> "n5";
}
