digraph OpsSpecTree {
  graph [rankdir=LR, bgcolor="white"];
  node [shape=box, style="rounded,filled", fillcolor="white", fontname="Helvetica"];
  edge [color="#666666"];
  subgraph "cluster_ops" {
    label="ops";
    color="#bbbbbb";
    style="rounded,filled";
    fillcolor="#e8f0fe";
    "n1" [label="n1 average (ops) field=Growth rate of HICP (%)"];
  }
  subgraph "cluster_ops2" {
    label="ops2";
    color="#bbbbbb";
    style="rounded,filled";
    fillcolor="#e8f5e9";
    "n2" [label="n2 filter (ops2) field=Growth rate of HICP (%)"];
  }
  subgraph "cluster_ops3" {
    label="ops3";
    color="#bbbbbb";
    style="rounded,filled";
    fillcolor="#e8f5e9";
    "n3" [label="n3 count (ops3) field=Month"];
  }
  "n1" -> "n2";
  "n2" -> "n3";
}
