digraph OpsSpecTree {
  graph [rankdir=LR, bgcolor="white"];
  node [shape=box, style="rounded,filled", fillcolor="white", fontname="Helvetica"];
  edge [color="#666666"];
  subgraph "cluster_ops" {
    label="ops";
    color="#bbbbbb";
    style="rounded,filled";
    fillcolor="#e8f0fe";
    "n1" [label="n1 findExtremum (ops) field=SharePercentage group=Scotland"];
  }
  subgraph "cluster_ops2" {
    label="ops2";
    color="#bbbbbb";
    style="rounded,filled";
    fillcolor="#e8f5e9";
    "n2" [label="n2 findExtremum (ops2) field=SharePercentage group=England & Wales"];
  }
  subgraph "cluster_ops3" {
    label="ops3";
    color="#bbbbbb";
    style="rounded,filled";
    fillcolor="#e8f5e9";
    "n3" [label="n3 compare (ops3)"];
  }
  subgraph "cluster_ops4" {
    label="ops4";
    color="#bbbbbb";
    style="rounded,filled";
    fillcolor="#e8f5e9";
    "n4" [label="n4 diff (ops4) field=SharePercentage"];
  }
  "n1" -> "n3";
  "n2" -> "n3";
  "n1" -> "n4";
  "n2" -> "n4";
}
