digraph OpsSpecTree {
  graph [rankdir=LR, bgcolor="white"];
  node [shape=box, style="rounded,filled", fillcolor="white", fontname="Helvetica"];
  edge [color="#666666"];
  subgraph "cluster_ops" {
    label="ops";
    color="#bbbbbb";
    style="rounded,filled";
    fillcolor="#e8f0fe";
    "n1" [label="n1 lagDiff (ops) field=Population in millions"];
  }
  subgraph "cluster_ops2" {
    label="ops2";
    color="#bbbbbb";
    style="rounded,filled";
    fillcolor="#e8f5e9";
    "n2" [label="n2 findExtremum (ops2) field=Population in millions"];
  }
  "n1" -> "n2";
}
