digraph OpsSpecTree {
  graph [rankdir=LR, bgcolor="white"];
  node [shape=box, style="rounded,filled", fillcolor="white", fontname="Helvetica"];
  edge [color="#666666"];
  subgraph "cluster_ops" {
    label="ops";
    color="#bbbbbb";
    style="rounded,filled";
    fillcolor="#e8f0fe";
    "n1" [label="n1 retrieveValue (ops) field=Value in billion US dollars"];
    "n2" [label="n2 retrieveValue (ops) field=Value in billion US dollars"];
  }
  subgraph "cluster_ops2" {
    label="ops2";
    color="#bbbbbb";
    style="rounded,filled";
    fillcolor="#e8f5e9";
    "n3" [label="n3 diff (ops2) field=Value in billion US dollars"];
  }
  subgraph "cluster_ops3" {
    label="ops3";
    color="#bbbbbb";
    style="rounded,filled";
    fillcolor="#e8f5e9";
    "n4" [label="n4 findExtremum (ops3) field=Value in billion US dollars"];
  }
  "n1" -> "n3";
  "n2" -> "n3";
  "n3" -> "n4";
}
