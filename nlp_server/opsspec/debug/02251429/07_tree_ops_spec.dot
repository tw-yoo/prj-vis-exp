digraph OpsSpecTree {
  graph [rankdir=LR, bgcolor="white"];
  node [shape=box, style="rounded,filled", fillcolor="white", fontname="Helvetica"];
  edge [color="#666666"];
  subgraph "cluster_ops" {
    label="ops";
    color="#bbbbbb";
    style="rounded,filled";
    fillcolor="#e8f0fe";
    "n1" [label="n1 average (ops) field=Value group=Investment"];
    "n2" [label="n2 average (ops) field=Value group=Lending"];
  }
}
